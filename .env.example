# ===========================================
# CONFIGURACIÓN DE API KEYS
# ===========================================
# Copia este archivo como .env y completa los valores

# GROQ API (Para Chat IA)
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_de_groq

# GOOGLE OAUTH
# Obtener en: Google Cloud Console > APIs y servicios > Credenciales
GOOGLE_OAUTH_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=tu_client_secret

# GOOGLE MAPS API KEY
# Obtener en: Google Cloud Console > APIs y servicios > Credenciales
GOOGLE_MAPS_API_KEY=tu_api_key_de_maps

# GOOGLE DRIVE FOLDER ID
# ID de la carpeta donde se guardarán los PDFs
DRIVE_FOLDER_ID=id_de_tu_carpeta_de_drive

# ===========================================
# FIREBASE (Configurar en Firebase Console)
# ===========================================
# Obtener de: Firebase Console > Project Settings > Your apps

FIREBASE_API_KEY=tu_api_key
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
FIREBASE_APP_ID=tu_app_id
